{
  "expo": {
    "name": "The Dodge Club",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/tdc-logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B5E2F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "co.uk.thedodgeclub",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Used to set your profile photo",
        "NSCameraUsageDescription": "Used to scan QR codes for event check-in",
        "NSUserNotificationUsageDescription": "We'll send you event reminders and check-in alerts",
        "NSLocationWhenInUseUsageDescription": "Used to show events near your location",
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "2"
    },
    "android": {},
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://thedodgeclub.co.uk"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-video",
      "expo-notifications",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.co.uk.thedodgeclub",
          "enableGooglePay": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "83ab4f6f-d594-4366-9424-db4cd54684f9"
      }
    },
    "owner": "tdc26"
  }
}
